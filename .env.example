# =============================================================
# Tavola ERP — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# =============================================================

# ── Banco de Dados (Supabase) ─────────────────────────────────
# Obtenha em: https://supabase.com → Project Settings → Database
# Use "Transaction pooler" para DATABASE_URL e "Direct connection" para DIRECT_URL
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].supabase.com:5432/postgres"

# ── Clerk Auth ────────────────────────────────────────────────
# Obtenha em: https://dashboard.clerk.com → [Seu App] → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# URLs de redirecionamento do Clerk
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
